# =============================================================================
# SIGMA INTELLIGENCE PLATFORM — Environment Variables
# Step 1: Copy this file to .env
# Step 2: Fill in YOUR values below (AWS, Snowflake, ARNs)
# Step 3: Run python lab/create_agents.py — it fills in the Bedrock IDs automatically
# =============================================================================

# AWS
AWS_DEFAULT_REGION=us-east-1
SIGMA_S3_BUCKET=sigma-datatech-YOURNAME
ALERT_EMAIL=your@email.com

# Bedrock — auto-filled by python lab/create_agents.py (do not edit manually)
SUPERVISOR_AGENT_ID=
SUPERVISOR_ALIAS_ID=
KNOWLEDGE_BASE_ID=LOCAL
GUARDRAIL_ID=
GUARDRAIL_VERSION=DRAFT

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=SIGMA
SNOWFLAKE_WAREHOUSE=SIGMA_WH
SNOWFLAKE_SCHEMA=SILVER

# AWS resources — from your account
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNTID:sigma-alerts
LAMBDA_ROLE_ARN=arn:aws:iam::ACCOUNTID:role/sigma-lambda-role

# Lambda function under investigation (created by inject_failure.py)
PRODUCER_LAMBDA_NAME=sigma-data-producer
PRODUCER_LAMBDA_ALIAS=LIVE

# Optional: Langfuse observability — sign up free at https://langfuse.com
# Leave blank to skip (lab works without it)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
